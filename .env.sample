# Database — matches infrastructure/docker-compose.yml defaults
DATABASE_URL="postgresql://stylehub:stylehub_pass@localhost:5433/stylehub"

# Redis — matches infrastructure/docker-compose.yml defaults
REDIS_URL="redis://localhost:6379"

# Public business ID — sent as the x-business-id header by client-side fetch calls.
# Run `SELECT id FROM businesses LIMIT 1;` to find your business ID after seeding.
NEXT_PUBLIC_BUSINESS_ID="your-business-uuid-here"

# Business timezone — IANA identifier used for client-side date/time display.
NEXT_PUBLIC_BUSINESS_TIMEZONE="America/Chicago"
